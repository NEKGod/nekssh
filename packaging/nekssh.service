[Unit]
Description=NekSSH Web SSH and SFTP Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nekssh
Group=nekssh
EnvironmentFile=-/etc/nekssh/nekssh.env
ExecStart=/usr/bin/nekssh
Restart=on-failure
RestartSec=3
StateDirectory=nekssh
WorkingDirectory=/var/lib/nekssh
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/nekssh

[Install]
WantedBy=multi-user.target
